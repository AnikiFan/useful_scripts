#!/usr/bin/env bash

set -u
set -o pipefail

DESCRIPTION='
check_user_disk_usage

扫描用户目录，找出同时满足以下条件的用户并发送邮件告警：
1. 用户目录占用空间大于系统盘当前可用空间
2. 用户目录占用空间大于最低告警阈值

脚本通过状态目录记录已告警用户，避免重复发送。用户不再满足告警条件后，状态文件会被清除。
用户名与邮箱映射文件格式为每行一个 username=email@example.com。

示例：
  check_user_disk_usage --mount-point / --home-root /home --min-usage-gb 100 \
    --email-map-file /etc/disk-user-emails.conf --admin-email ops@example.com

  check_user_disk_usage --no-admin-copy --msmtp-config /root/.msmtprc
'

MOUNT_POINT="/"
HOME_ROOT="/home"
MIN_USAGE_GB=100
EMAIL_MAP_FILE="/etc/disk-user-emails.conf"
MSMTP_CONFIG="/root/.msmtprc"
STATE_DIR="/var/lib/user-disk-alert"
LOG_TAG="user-disk-monitor"
SEND_ADMIN_COPY=true
ADMIN_EMAIL="your_email@example.com"
MSMTP_BIN="msmtp"
CONFIRM_BEFORE_SEND=true

usage() {
    printf '%s\n' "$DESCRIPTION"
    printf '%s\n' \
        "用法：" \
        "  check_user_disk_usage [选项]" \
        "" \
        "选项：" \
        "  -m, --mount-point PATH       用于判断可用空间的挂载点，默认：${MOUNT_POINT}" \
        "      --home-root PATH         用户目录根路径，默认：${HOME_ROOT}" \
        "      --min-usage-gb GB        用户占用空间最低告警阈值，单位 GB，默认：${MIN_USAGE_GB}" \
        "      --email-map-file PATH    用户名与邮箱映射文件，默认：${EMAIL_MAP_FILE}" \
        "      --msmtp-config PATH      msmtp 配置文件，默认：${MSMTP_CONFIG}" \
        "      --state-dir PATH         告警状态目录，默认：${STATE_DIR}" \
        "      --log-tag TAG            syslog 日志标识，默认：${LOG_TAG}" \
        "      --admin-email EMAIL      管理员副本邮箱，默认：${ADMIN_EMAIL}" \
        "      --admin-copy             同时给管理员发送副本，默认开启" \
        "      --no-admin-copy          不给管理员发送副本" \
        "      --msmtp-bin PATH         msmtp 命令路径，默认：${MSMTP_BIN}" \
        "      --confirm               发送前要求用户确认，默认开启" \
        "      --no-confirm            发送前不要求用户确认" \
        "  -h, --help                   显示帮助"
}

die() {
    echo "错误：$*" >&2
    exit 1
}

is_positive_integer() {
    [[ "${1:-}" =~ ^[1-9][0-9]*$ ]]
}

while (($# > 0)); do
    case "$1" in
        -m|--mount-point)
            (($# >= 2)) || die "$1 需要一个参数"
            MOUNT_POINT="$2"
            shift 2
            ;;
        --home-root)
            (($# >= 2)) || die "$1 需要一个参数"
            HOME_ROOT="$2"
            shift 2
            ;;
        --min-usage-gb)
            (($# >= 2)) || die "$1 需要一个参数"
            MIN_USAGE_GB="$2"
            shift 2
            ;;
        --email-map-file)
            (($# >= 2)) || die "$1 需要一个参数"
            EMAIL_MAP_FILE="$2"
            shift 2
            ;;
        --msmtp-config)
            (($# >= 2)) || die "$1 需要一个参数"
            MSMTP_CONFIG="$2"
            shift 2
            ;;
        --state-dir)
            (($# >= 2)) || die "$1 需要一个参数"
            STATE_DIR="$2"
            shift 2
            ;;
        --log-tag)
            (($# >= 2)) || die "$1 需要一个参数"
            LOG_TAG="$2"
            shift 2
            ;;
        --admin-email)
            (($# >= 2)) || die "$1 需要一个参数"
            ADMIN_EMAIL="$2"
            shift 2
            ;;
        --admin-copy)
            SEND_ADMIN_COPY=true
            shift
            ;;
        --no-admin-copy)
            SEND_ADMIN_COPY=false
            shift
            ;;
        --msmtp-bin)
            (($# >= 2)) || die "$1 需要一个参数"
            MSMTP_BIN="$2"
            shift 2
            ;;
        --confirm)
            CONFIRM_BEFORE_SEND=true
            shift
            ;;
        --no-confirm)
            CONFIRM_BEFORE_SEND=false
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "未知参数：$1。使用 --help 查看帮助"
            ;;
    esac
done

is_positive_integer "$MIN_USAGE_GB" || die "--min-usage-gb 必须是正整数"
[[ -d "$MOUNT_POINT" ]] || die "挂载点不存在：${MOUNT_POINT}"
[[ -d "$HOME_ROOT" ]] || die "用户目录根路径不存在：${HOME_ROOT}"

for command_name in df du numfmt awk logger find basename tail tr hostname date mkdir; do
    if ! command -v "$command_name" >/dev/null 2>&1; then
        die "缺少命令：${command_name}"
    fi
done

if ! command -v "$MSMTP_BIN" >/dev/null 2>&1; then
    die "缺少 msmtp 命令：${MSMTP_BIN}"
fi

mkdir -p "$STATE_DIR"

HOSTNAME_VALUE="$(hostname -f 2>/dev/null || hostname)"
CURRENT_TIME="$(date '+%Y-%m-%d %H:%M:%S')"

AVAILABLE_BYTES="$(
    df -B1 --output=avail "$MOUNT_POINT" |
    tail -n 1 |
    tr -d '[:space:]'
)"

if [[ ! "$AVAILABLE_BYTES" =~ ^[0-9]+$ ]]; then
    logger -t "$LOG_TAG" "Unable to get available disk space"
    exit 1
fi

MIN_USAGE_BYTES=$((MIN_USAGE_GB * 1024 * 1024 * 1024))
AVAILABLE_GB=$((AVAILABLE_BYTES / 1024 / 1024 / 1024))

get_user_email() {
    local username="$1"

    [[ -f "$EMAIL_MAP_FILE" ]] || return 1

    awk -F= -v user="$username" '
        $1 == user {
            print $2
            exit
        }
    ' "$EMAIL_MAP_FILE"
}

send_alert() {
    local username="$1"
    local recipient="$2"
    local usage_bytes="$3"
    local usage_human="$4"
    local home_dir="$5"

    local recipients=("$recipient")
    local msmtp_args=()

    if [[ -n "$MSMTP_CONFIG" ]]; then
        msmtp_args+=(--file="$MSMTP_CONFIG")
    fi

    if [[ "$SEND_ADMIN_COPY" == true ]] &&
       [[ -n "$ADMIN_EMAIL" ]] &&
       [[ "$ADMIN_EMAIL" != "$recipient" ]]; then
        recipients+=("$ADMIN_EMAIL")
    fi

    {
        echo "From: Linux Disk Monitor"
        echo "To: ${recipient}"

        if [[ "$SEND_ADMIN_COPY" == true ]] &&
           [[ -n "$ADMIN_EMAIL" ]] &&
           [[ "$ADMIN_EMAIL" != "$recipient" ]]; then
            echo "Cc: ${ADMIN_EMAIL}"
        fi

        echo "Subject: [Disk Warning] Excessive disk usage on ${HOSTNAME_VALUE}"
        echo "Content-Type: text/plain; charset=UTF-8"
        echo
        echo "您好，${username}："
        echo
        echo "系统检测到您的用户目录占用空间较大，并且满足以下两个条件："
        echo
        echo "1. 您的占用空间大于系统盘当前可用空间"
        echo "2. 您的占用空间大于管理员设置的最低阈值"
        echo
        echo "主机：${HOSTNAME_VALUE}"
        echo "用户：${username}"
        echo "用户目录：${home_dir}"
        echo "您的占用空间：${usage_human}"
        echo "您的占用字节数：${usage_bytes}"
        echo "系统盘当前可用空间：${AVAILABLE_GB} GB"
        echo "最低告警阈值：${MIN_USAGE_GB} GB"
        echo "检测时间：${CURRENT_TIME}"
        echo
        echo "请及时检查并清理不再需要的数据。"
        echo
        echo "常用检查命令："
        echo "du -xhd1 '${home_dir}' 2>/dev/null | sort -hr | head -n 20"
        echo
        echo "此邮件由服务器磁盘监控程序自动发送。"
    } | "$MSMTP_BIN" \
        "${msmtp_args[@]}" \
        "${recipients[@]}"
}

confirm_send() {
    local username="$1"
    local recipient="$2"
    local usage_human="$3"
    local home_dir="$4"

    [[ "$CONFIRM_BEFORE_SEND" == true ]] || return 0

    if [[ ! -r /dev/tty ]]; then
        logger -t "$LOG_TAG" \
            "Alert skipped for user=${username}: confirmation requested but no terminal is available"
        return 1
    fi

    printf '%s\n' \
        "即将发送用户磁盘告警：" \
        "  发送对象 To: ${recipient}" >/dev/tty

    if [[ "$SEND_ADMIN_COPY" == true ]] &&
       [[ -n "$ADMIN_EMAIL" ]] &&
       [[ "$ADMIN_EMAIL" != "$recipient" ]]; then
        printf '  发送对象 Cc: %s\n' "$ADMIN_EMAIL" >/dev/tty
    fi

    printf '%s\n' \
        "  主机: ${HOSTNAME_VALUE}" \
        "  用户: ${username}" \
        "  用户目录: ${home_dir}" \
        "  用户占用空间: ${usage_human}" >/dev/tty
    printf '确认发送？[y/N] ' >/dev/tty

    local answer
    IFS= read -r answer </dev/tty || return 1

    case "$answer" in
        y|Y|yes|YES)
            return 0
            ;;
        *)
            logger -t "$LOG_TAG" "Alert skipped by user confirmation: user=${username}"
            return 1
            ;;
    esac
}

find "$HOME_ROOT" \
    -mindepth 1 \
    -maxdepth 1 \
    -type d \
    -print0 |
while IFS= read -r -d '' home_dir; do
    username="$(basename "$home_dir")"
    state_file="${STATE_DIR}/${username}.alerted"

    usage_bytes="$(
        du -sx --block-size=1 "$home_dir" 2>/dev/null |
        awk '{print $1}'
    )"

    if [[ ! "$usage_bytes" =~ ^[0-9]+$ ]]; then
        logger -t "$LOG_TAG" \
            "Unable to calculate usage for user=${username}, path=${home_dir}"
        continue
    fi

    usage_human="$(
        numfmt --to=iec-i --suffix=B "$usage_bytes"
    )"

    if (( usage_bytes > AVAILABLE_BYTES &&
          usage_bytes > MIN_USAGE_BYTES )); then

        if [[ -f "$state_file" ]]; then
            logger -t "$LOG_TAG" \
                "Alert already active for user=${username}, usage=${usage_human}"
            continue
        fi

        recipient="$(get_user_email "$username" || true)"

        if [[ -z "$recipient" ]]; then
            logger -t "$LOG_TAG" \
                "No email configured for user=${username}, usage=${usage_human}"
            continue
        fi

        if confirm_send \
            "$username" \
            "$recipient" \
            "$usage_human" \
            "$home_dir"; then

            if send_alert \
                "$username" \
                "$recipient" \
                "$usage_bytes" \
                "$usage_human" \
                "$home_dir"; then

                {
                    echo "alert_time=${CURRENT_TIME}"
                    echo "usage_bytes=${usage_bytes}"
                    echo "available_bytes=${AVAILABLE_BYTES}"
                } > "$state_file"

                logger -t "$LOG_TAG" \
                    "Alert sent to ${recipient}: user=${username}, usage=${usage_human}"
            else
                logger -t "$LOG_TAG" \
                    "Failed to send alert: user=${username}, recipient=${recipient}"
            fi
        fi
    else
        if [[ -f "$state_file" ]]; then
            rm -f "$state_file"

            logger -t "$LOG_TAG" \
                "Alert cleared for user=${username}, usage=${usage_human}"
        fi
    fi
done
