#!/bin/bash
# Runtime fallback editor/diff tool for chezmoi.
# Called with 1 arg for edit mode, 2 args for diff/merge mode.
set -euo pipefail

if [[ $# -eq 2 ]]; then
    # diff / merge mode
    if command -v code &>/dev/null; then
        exec code --wait --diff "$1" "$2"
    elif command -v nvim &>/dev/null; then
        exec nvim -d "$1" "$2" </dev/tty >/dev/tty
    else
        exec vim -d "$1" "$2" </dev/tty >/dev/tty
    fi
else
    # edit mode
    if command -v code &>/dev/null; then
        exec code --wait "$@"
    elif command -v nvim &>/dev/null; then
        exec nvim "$@" </dev/tty >/dev/tty
    else
        exec vim "$@" </dev/tty >/dev/tty
    fi
fi
