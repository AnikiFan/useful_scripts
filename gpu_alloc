#!/bin/bash
# gpu_alloc.sh - 自动分配空闲 GPU 的函数库
# 用法: source gpu_alloc.sh
#       acquire_gpus [最少GPU数] [最多GPU数] [显存利用率阈值%] [轮询间隔秒]
#
# 成功后会设置以下环境变量:
#   CUDA_VISIBLE_DEVICES  - 逗号分隔的 GPU ID
#   N_GPU_PER_NODE        - 实际分配到的 GPU 数量
#
# 示例:
#   acquire_gpus 2 4        # 至少 2 张才启动，最多拿 4 张，尽量多拿
#   acquire_gpus 4          # 至少 4 张，最多也是 4 张（固定数量）
#   acquire_gpus 2 8 10     # 显存利用率 < 10% 视为空闲
#   acquire_gpus 2 8 5 30   # 每 30 秒轮询一次

# 获取空闲 GPU 列表
# 参数: $1 = 显存利用率阈值 (默认 5%)
# 输出: 每行一个空闲 GPU ID
_get_free_gpus() {
    local threshold="${1:-5}"
    nvidia-smi --query-gpu=index,memory.used,memory.total \
        --format=csv,noheader,nounits 2>/dev/null \
    | while IFS=', ' read -r idx mem_used mem_total; do
        [[ -z "$idx" || -z "$mem_used" || -z "$mem_total" || "$mem_total" -eq 0 ]] && continue
        local usage=$(( mem_used * 100 / mem_total ))
        if [[ "$usage" -lt "$threshold" ]]; then
            echo "$idx"
        fi
    done
}

# 主函数: 阻塞式获取 GPU
# 参数:
#   $1 = 最少需要的 GPU 数量 (必填)
#   $2 = 最多占用的 GPU 数量 (默认 = $1)
#   $3 = 显存利用率阈值% (默认 5)
#   $4 = 轮询间隔秒 (默认 15)
acquire_gpus() {
    local n_min="${1:?用法: acquire_gpus <最少GPU数> [最多GPU数] [阈值%] [轮询秒]}"
    local n_max="${2:-$n_min}"
    local threshold="${3:-5}"
    local interval="${4:-15}"

    # 参数校验
    if [[ "$n_max" -lt "$n_min" ]]; then
        echo "[gpu_alloc] 错误: 最大数量(${n_max}) 不能小于最小数量(${n_min})" >&2
        return 1
    fi

    if ! command -v nvidia-smi &>/dev/null; then
        echo "[gpu_alloc] 错误: nvidia-smi 未找到" >&2
        return 1
    fi

    local total_gpus
    total_gpus=$(nvidia-smi --query-gpu=index --format=csv,noheader 2>/dev/null | wc -l)
    if [[ "$n_min" -gt "$total_gpus" ]]; then
        echo "[gpu_alloc] 错误: 至少需要 ${n_min} 张 GPU，但本机只有 ${total_gpus} 张" >&2
        return 1
    fi

    echo "[gpu_alloc] 请求 ${n_min}~${n_max} 张 GPU (阈值 <${threshold}%，轮询 ${interval}s)" >&2

    while true; do
        local free_gpus=()
        while IFS= read -r gpu_id; do
            [[ -n "$gpu_id" ]] && free_gpus+=("$gpu_id")
        done < <(_get_free_gpus "$threshold")

        local n_free="${#free_gpus[@]}"

        if [[ "$n_free" -ge "$n_min" ]]; then
            # 尽量多拿，但不超过 n_max
            local n_take="$n_free"
            if [[ "$n_take" -gt "$n_max" ]]; then
                n_take="$n_max"
            fi

            local selected=("${free_gpus[@]:0:$n_take}")
            local csv
            csv=$(IFS=,; echo "${selected[*]}")

            export CUDA_VISIBLE_DEVICES="$csv"
            export N_GPU_PER_NODE="$n_take"

            echo "[gpu_alloc] 已分配 ${n_take} 张 GPU: CUDA_VISIBLE_DEVICES=${csv}" >&2
            return 0
        else
            local now
            now=$(date '+%H:%M:%S')
            echo "[gpu_alloc] ${now} 空闲 GPU 不足 (空闲: ${n_free}，需要: ≥${n_min})，${interval}s 后重试..." >&2
            sleep "$interval"
        fi
    done
}

# 释放 GPU（清除环境变量）
release_gpus() {
    unset CUDA_VISIBLE_DEVICES
    unset N_GPU_PER_NODE
    echo "[gpu_alloc] 已释放 GPU 环境变量" >&2
}
